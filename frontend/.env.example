# Backend API base — must end with /api/v1 (not just http://localhost:3000).
# In dev, omit this to use same-origin /api/v1 (Vite proxies /api → backend :3000).
# VITE_API_URL=http://localhost:3000/api/v1

# Supabase — browser client (publishable / anon key only)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_or_anon_key

# Optional — "Book Consultation" on results opens mailto: this address (annual savings > $6k).
# VITE_CONSULT_EMAIL=hello@yourcompany.com
